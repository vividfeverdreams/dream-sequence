# --- Database (Supabase Postgres) ---
# Pooled connection (port 6543, pgbouncer) for the app at runtime / serverless:
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) for Prisma migrations:
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

AUTH_SECRET="replace-with-a-long-random-string"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase Storage (rendered videos) ---
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="renders"

# --- OpenAI (moderation/ranking + Sora) ---
OPENAI_API_KEY=""
OPENAI_TEXT_MODEL="gpt-5.4-mini"
OPENAI_VIDEO_MODEL="sora-2"

# --- Twilio SMS intake (optional) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Optional: demo loop used when OPENAI_API_KEY is absent.
DEMO_LOOP_URL="https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4"
